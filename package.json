{
  "name": "globus",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/fix-scripts.js && prettier --write \"dist/**/*.html\" --ignore-path .prettierignore",
    "build:agent": "node scripts/build-agent.js",
    "preview": "npx --yes serve dist -l 4323",
    "preview:agent": "npx --yes serve dist-agent -l 4322",
    "astro": "astro",
    "lint": "eslint src"
  },
  "dependencies": {
    "astro": "^7.0.2",
    "globby": "^16.2.0",
    "photoswipe": "^5.4.4",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "astro-eslint-parser": "^2.0.0",
    "autoprefixer": "^10.5.1",
    "cssnano": "^8.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.0.0",
    "globals": "^17.7.0",
    "postcss": "^8.5.15",
    "postcss-sort-media-queries": "^6.6.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
