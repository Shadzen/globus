---
// src/components/about/AboutMap.astro
---

<section class="about-map _dark">
    <div class="section-container">
        <div class="about-map-text">
            <div class="about-map-block">
                <h3>Адрес</h3>
                <p>Новосибирск, ул. Советская, дом 64, оф. 403.</p>
            </div>
            <div class="about-map-block">
                <h3>График работы</h3>
                <p>
                    Пн — Пт: 10:00 — 19:00<br />Суббота: 11:00 — 18:00
                </p>
            </div>
        </div>
        <div
            class="about-map-image"
            id="about-yandex-map"
            data-lat="55.048513"
            data-lng="82.911446"
            data-zoom="16"
            data-hint="Глобус-тур"
            data-balloon="Новосибирск, ул. Советская, дом 64, оф. 403"
            data-preset="islands#redDotIcon"
            data-api-key=""
        >
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .about-map {
        @include adaptive(padding-top, 80, 40);
        @include adaptive(padding-bottom, 80, 60);

        .section-container {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;

            @include mobile {
                flex-direction: column;
                @include adaptive(gap, 38, 38);
            }
        }

        .about-map-text {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 106, 50);
            @include adaptive(padding-top, 36, 0);
            flex-shrink: 0;

            @include mobile {
                order: 2;
                width: 100%;
            }
        }

        .about-map-block {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 6, 20);
        }

        .about-map-text .about-map-block {
            h3 {
                @include adaptive(font-size, 28, 26);
                color: var(--color-globus-cream);
            }

            p {
                @include adaptive(font-size, 26, 26);
                color: var(--color-globus-light-blue);
                @include adaptive(width, 70%, 100%);
            }
        }

        .about-map-image {
            @include adaptive(width, 1141, 450);
            @include adaptive(height, 357, 230);
            flex-shrink: 0;
            overflow: hidden;

            @include mobile {
                order: 1;
                width: 100%;
            }
        }
    }
</style>
