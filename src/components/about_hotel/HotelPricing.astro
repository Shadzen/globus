---
import SearchForm from '@/components/main/SearchForm.astro'

const pricingData = [
    {
        accommodation: 'Комфорт',
        meal: 'AI',
        price: 'от 1960 $',
    },
    {
        accommodation: 'Эконом',
        meal: 'BB',
        price: 'от 1500$',
    },
    {
        accommodation: 'Комфорт+',
        meal: 'BB',
        price: 'от 2340 $',
    },
    {
        accommodation: 'Комфорт',
        meal: 'AI',
        price: 'от 1960 $',
    },
    {
        accommodation: 'Эконом',
        meal: 'BB',
        price: 'от 1500$',
    },
    {
        accommodation: 'Комфорт+',
        meal: 'BB',
        price: 'от 2340 $',
    },
]
---

<section class="hotel-pricing">
    <!-- Search form (same fields as on main: departure date + travellers) -->
    <SearchForm
        variant="inline"
        fields={{
            city: false,
            country: false,
            dates: true,
            nights: false,
            tourists: true,
        }}
    />

    <!-- Pricing Table -->
    <div class="pricing-table-container">
        <div class="pricing-table">
            <!-- Table Header -->
            <div class="pricing-header">
                <div class="header-cell">Размещение</div>
                <div class="header-cell">Питание</div>
                <div class="header-cell">Цена</div>
            </div>

            <!-- Table Rows -->
            {
                pricingData.map((item) => (
                    <div class="pricing-row">
                        <div class="pricing-cell">{item.accommodation}</div>
                        <div class="pricing-cell">{item.meal}</div>
                        <div class="pricing-cell pricing-cell-price">
                            <button class="button _sized _outline">{item.price}</button>
                        </div>
                    </div>
                ))
            }
        </div>

        <button class="button _sized">написать менеджеру</button>
    </div>
</section>

<style lang="scss" is:global>
    .hotel-pricing {
        // Pricing Table
        .pricing-table-container {
            @include side-paddings;
            @include adaptive(padding-top, 52, 30);

            > .button {
                @include adaptive(margin-top, 24, 30);
                margin-left: auto;
                margin-right: auto;
            }
        }

        .pricing-table {
            display: flex;
            flex-direction: column;
        }

        .pricing-header {
            display: flex;
            @include adaptive(padding-bottom, 12, 6);
            @include adaptive(padding-left, 54, 0);
            @include adaptive(padding-right, 54, 0);
            border-bottom: 1px solid var(--color-globus-sand);
        }

        .header-cell {
            @include font-circe-regular;
            @include adaptive(font-size, 20, 18);
            line-height: 1.2;
            color: var(--color-globus-blue);
            opacity: 0.6;

            &:nth-child(1) {
                @include adaptive(width, 44%, 36%);
            }

            &:nth-child(2) {
                @include adaptive(width, 35%, 24%);
            }

            &:nth-child(3) {
                flex: 1;
                @include adaptive(padding-right, 5%, 14%);
                text-align: right;
            }
        }

        .pricing-row {
            display: flex;
            align-items: center;
            @include adaptive(padding-top, 12, 12);
            @include adaptive(padding-bottom, 12, 12);
            @include adaptive(padding-left, 54, 0);
            @include adaptive(padding-right, 54, 0);
            border-bottom: 1px solid var(--color-globus-sand);

            .button {
                @include adaptive(font-size, 26, 26);
                color: var(--color-globus-blue);
                @include adaptive(min-width, 200, 140);
                @include adaptive(height, 40, 40);
                text-transform: none;
                letter-spacing: normal;
            }
        }

        .pricing-cell {
            @include font-circe-regular;
            @include adaptive(font-size, 26, 26);
            line-height: 1.2;
            color: var(--color-globus-blue);

            &:nth-child(1) {
                @include adaptive(width, 44%, 36%);
            }

            &:nth-child(2) {
                @include adaptive(width, 35%, 24%);
                @include adaptive(padding-left, 1.5%, 4%);
            }

            &:nth-child(3) {
                flex: 1;
            }
        }

        .pricing-cell-price {
            display: flex;
            justify-content: flex-end;
        }
    }
</style>
