---
import promoTourPhoto from '@/assets/images/promo_tour/promo-tour-photo-1.jpg'

const tourInfo = {
    title: 'приглашаем в рекламный тур на Мальдивы',
    image: promoTourPhoto,
    details: [
        'Даты: 22.07 - 01.08.2025г.',
        'Продолжительность: 9 ночей / 10 дней',
        'Fly Dubai ч/з Дубай, с багажом',
    ],
    prices: [
        {
            amount: '2 340 $',
            label: '(с перелетом)',
        },
        {
            amount: '1400 $',
            label: '(без перелета)',
        },
    ],
}
---

<section class="promo-tour-info-section">
    <div class="section-container">
        <h2>{tourInfo.title}</h2>

        <div class="promo-tour-info-content">
            <div class="promo-tour-info-image">
                <img src={tourInfo.image.src} alt={tourInfo.title} />
            </div>

            <div class="promo-tour-info-details">
                <ul>
                    {tourInfo.details.map((detail) => <li>{detail}</li>)}
                </ul>

                <div class="promo-tour-info-prices">
                    {
                        tourInfo.prices.map((price) => (
                            <div class="button _sized _outline">
                                <span class="button-amount">{price.amount}</span>
                                <span class="button-label">{price.label}</span>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .promo-tour-info-section {
        @include adaptive(margin-top, 120, 60);

        .promo-tour-info-content {
            @include adaptive(margin-top, 60, 30);
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            @include adaptive(gap, 90, 30);

            @include mobile {
                grid-template-columns: 1fr;
            }
        }

        .promo-tour-info-image {
            @include adaptive(height, 377, 231);
            width: 100%;
            overflow: hidden;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }
        }

        .promo-tour-info-details {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 50, 30);
        }

        ul {
            @include adaptive(gap, 25, 20);
        }

        .promo-tour-info-prices {
            display: flex;
            @include adaptive(gap, 37, 20);
            flex-wrap: wrap;
        }

        .button {
            @include adaptive(min-width, 270, auto);
            flex-direction: column;
            color: var(--color-globus-blue);
        }
    }
</style>
