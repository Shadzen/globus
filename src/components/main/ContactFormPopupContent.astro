---
// src/components/main/ContactFormPopupContent.astro
// Popup variant of contact form (tourist structure, light/white background).
import SocialButtons from '@/components/common/SocialButtons.astro'
---

<div class="contact-form">
    <h2 id="contact-title" data-modal-focus>Открываем мир</h2>

    <div class="contact-form-container">
        <div class="contact-form-left">
            <div class="contact-form-info">
                <h3>Контакты для связи</h3>

                <div class="contact-form-item">
                    <span class="contact-form-label">Экстренный телефон</span>
                    <div class="contact-form-separator"></div>
                    <a href="tel:+7 383 2000 500" class="contact-form-value"> +7 383 2000 500 </a>
                </div>

                <div class="contact-form-item">
                    <span class="contact-form-label">Телефон</span>
                    <div class="contact-form-separator"></div>
                    <a href="tel:+7 383 2000 500" class="contact-form-value"> +7 383 2000 500 </a>
                </div>

                <div class="contact-form-item">
                    <span class="contact-form-label">Email</span>
                    <div class="contact-form-separator"></div>
                    <a href="mailto:info@globus-tour.ru" class="contact-form-value">
                        info@globus-tour.ru
                    </a>
                </div>
            </div>

            <div class="contact-form-social">
                <h3>Быстрая связь в месенджерах</h3>
                <SocialButtons
                    variant="default"
                    telegramHref="https://t.me/+79130637716"
                    whatsappHref="https://wa.me/79130637716"
                />
            </div>
        </div>

        <div class="contact-form-right">
            <form class="contact-form-form">
                <h3>Напишите прямо сейчас</h3>

                <input
                    type="text"
                    id="contact-name"
                    name="name"
                    class="contact-form-form-input"
                    placeholder="Имя"
                    aria-label="Имя"
                    autocomplete="name"
                />
                <input
                    type="tel"
                    id="contact-phone"
                    name="phone"
                    class="contact-form-form-input"
                    placeholder="Телефон"
                    aria-label="Телефон"
                    autocomplete="tel"
                />
                <input
                    type="text"
                    id="contact-comment"
                    name="comment"
                    class="contact-form-form-input"
                    placeholder="Комментарий"
                    aria-label="Комментарий"
                    autocomplete="off"
                />

                <div class="contact-form-checkbox">
                    <input type="checkbox" id="contact-agree" name="agree" required />
                    <label for="contact-agree">
                        Я принимаю условия <a href="#">Пользовательского соглашения</a> и подтверждаю
                        <a href="#">согласие на обработку моих персональных данных</a>.
                    </label>
                </div>

                <button type="submit" class="button _sized">Отправить</button>
            </form>
        </div>
    </div>
</div>

<style lang="scss" is:global>
    .contact-form {
        display: flex;
        flex-direction: column;
        @include adaptive(gap, 80, 40);

        .contact-form-container {
            display: flex;
            @include adaptive(gap, 100, 60);

            @include mobile {
                flex-direction: column;
            }

            > * {
                flex: 1;
            }
        }

        h3 {
            @include adaptive(font-size, 28, 28);
            color: var(--color-globus-blue);

            @include mobile {
                text-align: center;
            }
        }

        .contact-form-left {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 32, 60);

            @include mobile {
                order: 2;
            }
        }

        .contact-form-info {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 40, 24);
        }

        .contact-form-item {
            width: 100%;
            @include flex-center-start;
            @include adaptive(gap, 24, 14);
            // @include adaptive(width, 74%, 100%);

            @include mobile {
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        .contact-form-label {
            @include adaptive(font-size, 16, 18);
            text-transform: uppercase;
            @include adaptive(letter-spacing, 3.2, 3.2);
            opacity: 0.5;

            @include mobile {
                width: 100%;
                text-align: center;
            }
        }

        .contact-form-separator {
            height: 1px;
            flex: 1;
            background: var(--color-globus-sand);

            @include mobile {
                display: none;
            }
        }

        .contact-form-value {
            @include font-kudry-sans;
            @include adaptive(font-size, 28, 28);
            text-transform: uppercase;
            text-decoration: none;
        }

        .contact-form-social {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 24, 24);
            @include adaptive(align-items, flex-start, center);
        }

        .contact-form-right {
            display: flex;
            align-items: flex-start;

            @include mobile {
                order: 1;
            }
        }

        .contact-form-form {
            width: 100%;
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 32, 32);
        }

        .contact-form-form-input {
            background: transparent;
            border: none;
            border-bottom: 1px solid color-mix(in srgb, var(--color-globus-sand) 50%, transparent);
            @include font-circe-regular;
            @include adaptive(font-size, 18, 16);
            line-height: 1.2;
            color: var(--color-globus-blue);
            outline: none;
            transition: border-color 0.3s;
            @include adaptive(padding-top, 8, 8);
            @include adaptive(padding-bottom, 8, 8);

            &::placeholder {
                @include font-circe-regular;
                @include adaptive(font-size, 16, 18);
                line-height: 1.6;
                color: var(--color-globus-blue);
                text-transform: uppercase;
                @include adaptive(letter-spacing, 3.2, 3.2);
                opacity: 0.5;
            }

            &:focus {
                border-bottom-color: var(--color-globus-sand);
            }
        }

        .contact-form-checkbox {
            display: flex;
            @include adaptive(gap, 12, 12);
            align-items: flex-start;

            input[type='checkbox'] {
                @include adaptive(width, 18, 18);
                @include adaptive(height, 18, 18);
                flex-shrink: 0;
                appearance: none;
                border: 1px solid var(--color-globus-sand);
                border-radius: 4px;
                cursor: pointer;
                transition: all 0.3s;
                margin: 0;
                margin-top: 2px;

                &:checked {
                    background: var(--color-globus-sand);
                    border-color: var(--color-globus-sand);
                }

                &:hover {
                    opacity: 0.8;
                }
            }

            label {
                @include font-circe-regular;
                @include adaptive(font-size, 14, 16);
                line-height: 1.4;
                color: var(--color-globus-blue);
                opacity: 0.7;
                cursor: pointer;

                a {
                    color: inherit;
                    font-size: inherit;
                    font-family: inherit;
                    letter-spacing: inherit;
                    white-space: normal;
                }
            }
        }

        .button._sized {
            @include adaptive(width, 222, 100%);
            align-self: flex-start;
        }
    }
</style>
