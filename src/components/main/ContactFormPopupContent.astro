---
// src/components/main/ContactFormPopupContent.astro
// Popup variant of contact form (tourist structure, light/white background).
import SocialButtons from '@/components/common/SocialButtons.astro'

interface Props {
    userType?: 'tourist' | 'agent'
}

const { userType = 'tourist' } = Astro.props
const base = import.meta.env.BASE_URL
const managersContactsHref = `${base}${userType}/about#contacts-tabs-wrapper`
const popupTitle = userType === 'agent' ? 'Открываем мир для вас' : 'Открываем мир'
---

<div class="contact-form-popup">
    <h2 id="contact-title" data-modal-focus>{popupTitle}</h2>

    <div class="contact-form-container">
        <div class="contact-form-left">
            <div class="contacts-info">
                <h3>Контакты для связи</h3>

                <div class="contacts-info-item">
                    <span class="contacts-info-label">Экстренный телефон</span>
                    <div class="contacts-info-separator"></div>
                    <a href="tel:+7 383 2000 500" class="contacts-info-value"> +7 383 2000 500 </a>
                </div>

                <div class="contacts-info-item">
                    <span class="contacts-info-label">Телефон</span>
                    <div class="contacts-info-separator"></div>
                    <a href="tel:+7 383 2000 500" class="contacts-info-value"> +7 383 2000 500 </a>
                </div>

                <div class="contacts-info-item">
                    <span class="contacts-info-label">Email</span>
                    <div class="contacts-info-separator"></div>
                    <a href="mailto:info@globus-tour.ru" class="contacts-info-value">
                        info@globus-tour.ru
                    </a>
                </div>
            </div>

            {
                userType === 'agent' && (
                    <a
                        href={managersContactsHref}
                        class="button _sized _outline contacts-managers-link"
                    >
                        Контакты менеджеров
                    </a>
                )
            }

            <div class="contacts-social">
                <h3>Быстрая связь в месенджерах</h3>
                <SocialButtons
                    variant="default"
                    maxHref="#"
                    messageHref="#"
                    telegramHref="#"
                />
            </div>
        </div>

        <div class="contact-form-right">
            <form class="contact-form">
                <h3>Напишите прямо сейчас</h3>

                <input
                    type="text"
                    id="contact-name"
                    name="name"
                    class="contact-form-input"
                    placeholder="Имя"
                    aria-label="Имя"
                    autocomplete="name"
                />
                <input
                    type="tel"
                    id="contact-phone"
                    name="phone"
                    class="contact-form-input"
                    placeholder="Телефон"
                    aria-label="Телефон"
                    autocomplete="tel"
                />
                <input
                    type="text"
                    id="contact-comment"
                    name="comment"
                    class="contact-form-input"
                    placeholder="Комментарий"
                    aria-label="Комментарий"
                    autocomplete="off"
                />

                <div class="contact-form-checkbox">
                    <input type="checkbox" id="contact-agree-1" name="agree" required />
                    <label for="contact-agree-1">
                        Я принимаю условия
                        <a href="/polzovatelskoe-soglashenie/">Пользовательского соглашения</a>.
                    </label>
                    <input type="checkbox" id="contact-agree-2" name="agree" required />
                    <label for="contact-agree-2">
                        Я подтверждаю
                        <a href="/politika-konfidenczialnosti/">согласие на обработку моих персональных данных</a>.
                    </label>
                </div>

                <button type="submit" class="button _sized">Отправить</button>
            </form>
        </div>
    </div>
</div>

<style lang="scss" is:global>
    .contact-form-popup {
        display: flex;
        flex-direction: column;
        @include adaptive(gap, 80, 40);

        .contact-form-container {
            display: flex;
            @include adaptive(gap, 100, 60);

            @include mobile {
                flex-direction: column;
            }
        }

        h3 {
            @include adaptive(font-size, 28, 28);
            color: var(--color-globus-blue);

            @include mobile {
                text-align: center;
            }
        }

        .contact-form-left {
            flex: 1;
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 32, 60);

            @include mobile {
                order: 2;
            }
        }

        .contacts-info-item {
            @include adaptive(gap, 24, 14);
            width: 100%;
        }

        .contact-form-right {
            flex: 1;
            display: flex;
            align-items: flex-start;

            @include mobile {
                order: 1;
            }
        }

        .button._sized {
            @include adaptive(width, 222, 100%);
            align-self: flex-start;
        }

        .contacts-managers-link.button._sized {
            width: 100%;
            isolation: isolate;
            background-color: transparent;
            transition: transform 0.3s ease;

            &::before {
                content: '';
                position: absolute;
                inset: -2px;
                border-radius: inherit;
                background-color: var(--color-globus-sand);
                opacity: 0;
                transition: opacity 0.3s ease;
                z-index: -1;
            }

            &:hover {
                background: transparent;
                color: var(--color-globus-cream);
                opacity: 1;
                transform: translateY(-2px);

                &::before {
                    opacity: 1;
                }
            }

            &:active {
                transform: translateY(0);
            }
        }
    }
</style>
