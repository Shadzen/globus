---
// src/components/main/ContactForm.astro
import phoneIcon from '@/assets/icons/phone-accent.svg'
import mailIcon from '@/assets/icons/mail-accent.svg'
import telegramIcon from '@/assets/icons/telegram-accent-borderless.svg'
import telegramAccentIcon from '@/assets/icons/telegram-accent.svg'

interface Props {
    userType?: 'tourist' | 'agent'
}

const { userType = 'tourist' } = Astro.props
---

<section class="contact-form-section _dark" class:list={{ _agent: userType === 'agent' }}>
    {
        userType === 'tourist' ?
            <div class="section-container _alt-paddings">
                <div class="contact-left">
                    <h2>Открываем мир</h2>

                    <div class="contacts-info">
                        <div class="contacts-info-item">
                            <span class="contacts-info-label">Телефон</span>
                            <div class="contacts-info-separator" />
                            <div class="social-icons">
                                <a href="#" class="social-icon" aria-label="Telegram">
                                    <img src={telegramAccentIcon.src} alt="" />
                                </a>
                            </div>
                            <a href="tel:880020006578" class="contacts-info-value">
                                8 800 2000 6578
                            </a>
                        </div>

                        <div class="contacts-info-item">
                            <span class="contacts-info-label">Email</span>
                            <div class="contacts-info-separator" />
                            <a href="mailto:info@globus-tour.ru" class="contacts-info-value">
                                info@globus-tour.ru
                            </a>
                        </div>
                    </div>

                    <form class="newsletter-form">
                        <input
                            type="email"
                            id="newsletter-email"
                            name="email"
                            placeholder="Подпишись на новости"
                            class="newsletter-input"
                            aria-label="Email для подписки"
                            autocomplete="email"
                        />
                        <button type="submit" class="newsletter-btn" aria-label="Подписаться">
                            <svg
                                width="39"
                                height="32"
                                viewBox="0 0 39 32"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M37.5 16L1.5 16M37.5 16L22.5 31M37.5 16L22.5 1"
                                    stroke="white"
                                    stroke-width="2"
                                />
                            </svg>
                        </button>
                    </form>
                </div>

                <div class="contact-right">
                    <form class="contact-form">
                        <h3 class="contact-form-title">Напишите прямо сейчас</h3>

                        <input
                            type="text"
                            id="contact-name"
                            name="name"
                            class="contact-form-input"
                            placeholder="Имя"
                            aria-label="Имя"
                            autocomplete="name"
                        />
                        <input
                            type="tel"
                            id="contact-phone"
                            name="phone"
                            class="contact-form-input"
                            placeholder="Телефон"
                            aria-label="Телефон"
                            autocomplete="tel"
                        />
                        <input
                            type="text"
                            id="contact-comment"
                            name="comment"
                            class="contact-form-input"
                            placeholder="Комментарий"
                            aria-label="Комментарий"
                            autocomplete="off"
                        />

                        <div class="contact-form-checkbox">
                            <input type="checkbox" id="contact-agree" name="agree" required />
                            <label for="contact-agree">
                                Я принимаю условия <a href="#">Пользовательского соглашения</a> и
                                подтверждаю
                                <a href="#">согласие на обработку моих персональных данных</a>.
                            </label>
                        </div>

                        <button type="submit" class="button _sized">
                            Отправить
                        </button>
                    </form>
                </div>
            </div>
        :   <div class="contact-agent-container _alt-paddings">
                <h2>Открываем мир</h2>

                <div class="contact-agent-buttons">
                    <a href="tel:880020006578" class="button _sized _outline">
                        <img src={phoneIcon.src} alt="" />
                        <span>8 800 2000 6578</span>
                    </a>

                    <a href="mailto:info@globus-tour.ru" class="button _sized _outline">
                        <img src={mailIcon.src} alt="" />
                        <span>info@globus-tour.ru</span>
                    </a>

                    <a href="#" class="button _sized _outline">
                        <img src={telegramIcon.src} alt="" />
                        <span>Группа в ТГ</span>
                    </a>

                    <form class="newsletter-form">
                        <input
                            type="email"
                            id="newsletter-email-agent"
                            name="email"
                            placeholder="Подпишись на новости"
                            class="newsletter-input"
                            aria-label="Email для подписки"
                            autocomplete="email"
                        />
                        <button type="submit" class="newsletter-btn" aria-label="Подписаться">
                            <svg
                                width="39"
                                height="32"
                                viewBox="0 0 39 32"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M37.5 16L1.5 16M37.5 16L22.5 31M37.5 16L22.5 1"
                                    stroke="white"
                                    stroke-width="2"
                                />
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
    }
</section>

<style lang="scss" is:global>
    .contact-form-section {
        @include adaptive(margin-top, 120, 60);
        @include adaptive(padding-top, 98, 60);
        @include adaptive(padding-bottom, 98, 60);
        @include side-paddings;

        .section-container {
            display: flex;
            @include adaptive(gap, 16, 60);

            > * {
                flex: 1;
            }

            @include mobile {
                flex-direction: column;
            }
        }

        .contact-left {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 93, 32);

            h2 {
                @include adaptive(text-align, left, center);
            }
        }

        .contacts-info-item {
            @include adaptive(gap, 36, 14);
            @include adaptive(width, 74%, 100%);
        }

        .contacts-info-value {
            color: var(--color-globus-cream);
        }

        .social-icons {
            display: flex;
            @include adaptive(gap, 14, 12);
            align-items: center;
        }

        .social-icon {
            @include adaptive(width, 40, 45);
            @include adaptive(height, 40, 45);
            display: block;
            transition: transform 0.3s;

            img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

            &:hover {
                transform: scale(1.1);
            }
        }

        .newsletter-form {
            position: relative;
            display: flex;
            align-items: center;
            @include adaptive(width, 500, 100%);
            @include adaptive(height, 60, 64);
            border-style: solid;
            border-color: var(--color-globus-sand);
            @include adaptive(border-width, 2, 2);
            border-right: none;
            border-radius: 500px;
            // overflow: hidden;
        }

        .newsletter-input {
            flex: 1;
            height: 100%;
            background: transparent;
            border: none;
            @include adaptive(padding-left, 45, 24);
            @include adaptive(padding-right, 20, 16);
            @include font-circe-regular;
            @include adaptive(font-size, 16, 18);
            line-height: 1.6;
            color: var(--color-globus-cream);
            text-transform: uppercase;
            @include adaptive(letter-spacing, 3.2, 3.2);
            outline: none;

            &::placeholder {
                color: var(--color-globus-cream);
                opacity: 0.5;
            }
        }

        .newsletter-btn {
            @include adaptive(width, 60, 64);
            @include adaptive(height, 60, 64);
            background: var(--color-globus-sand);
            border: 1px solid var(--color-globus-sand);
            border-radius: 50%;
            @include flex-center;
            cursor: pointer;
            transition: all 0.3s;
            flex-shrink: 0;

            svg {
                @include adaptive(width, 39, 30);
                @include adaptive(height, 32, 24);
            }

            &:hover {
                transform: scale(1.05);
            }

            &:active {
                transform: scale(0.95);
            }
        }

        .contact-right {
            display: flex;
            align-items: flex-start;

            @include mobile {
                order: 1;
            }
        }

        .contact-form {
            @include adaptive(gap, 40, 40);
        }

        &:not(._agent) .button {
            // @include adaptive(margin-top, 38, 38);
            @include adaptive(width, 222, 100%);
            align-self: flex-start;
        }
    }

    .contact-form-section._agent {
        .contact-agent-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            @include adaptive(gap, 58, 50);
        }

        .contact-agent-buttons {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            @include adaptive(gap, 40, 28);
            width: 100%;

            @include mobile {
                flex-direction: column;
                align-items: stretch;
            }
        }

        .button {
            @include adaptive(font-size, 24, 18);
        }

        .newsletter-form {
            @include adaptive(width, 416, auto);
        }
    }
</style>
