---
import managerPhoto from '@/assets/images/about/contact-photo-1.jpg'
import telegramIcon from '@/assets/icons/telegram-accent-borderless.svg'
import phoneIcon from '@/assets/icons/phone-accent.svg'
---

<section class="partner-contact-section _dark">
    <div class="section-container">
        <div class="partner-contact-card">
            <div class="partner-contact-avatar">
                <img src={managerPhoto.src} alt="Бубер Анастасия" loading="lazy" />
            </div>

            <div class="partner-contact-info">
                <h3>
                    Бубер<br />
                    Анастасия
                </h3>
                <p>
                    Руководитель отдела по работе с агентствами
                </p>
            </div>
        </div>

        <div class="partner-contact-buttons">
            <a href="tel:+79130637730" class="button _sized _outline">
                <img src={telegramIcon.src} alt="Telegram" />
                <span>8 913 063 77 30</span>
            </a>

            <a href="tel:+73833340586" class="button _sized _outline">
                <img src={phoneIcon.src} alt="Телефон" />
                <span class="button-numbers">
                    <span>+7 (383) 334-05-86,</span>
                    <span>334-05-89 доб. 725</span>
                </span>
            </a>

            <a href="mailto:dogovor@globus-tour.ru" class="button _sized">
                <span>dogovor@globus-tour.ru</span>
            </a>
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .partner-contact-section {
        @include adaptive(margin-top, 80, 60);
        @include adaptive(padding-top, 80, 40);
        @include adaptive(padding-bottom, 80, 40);

        .section-container {
            @include flex-center;
            @include adaptive(gap, 60, 40);
            flex-wrap: wrap;

            @include mobile {
                flex-direction: column;
            }
        }

        .partner-contact-card {
            display: flex;
            @include adaptive(gap, 25, 20);
            align-items: flex-start;

            @include mobile {
                flex-direction: column;
                align-items: center;
            }
        }

        .partner-contact-avatar {
            @include adaptive(width, 115, 111);
            @include adaptive(height, 115, 111);
            border-radius: 50%;
            overflow: hidden;
            flex-shrink: 0;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }
        }

        .partner-contact-info {
            display: flex;
            flex-direction: column;
            @include adaptive(gap, 7, 10);

            @include mobile {
                align-items: center;
                text-align: center;
                width: 65%;
            }

            h3 {
                @include adaptive(font-size, 28, 26);
                color: var(--color-globus-sand);
            }
        }

        .partner-contact-buttons {
            @include flex-center;
            @include adaptive(gap, 24, 20);
            flex-wrap: wrap;

            @include mobile {
                flex-direction: column;
                width: 100%;
            }

            .button._sized._outline {
                @include adaptive(font-size, 24, 18);
                @include adaptive(letter-spacing, 2.4, 2.4);
            }
        }
    }
</style>
