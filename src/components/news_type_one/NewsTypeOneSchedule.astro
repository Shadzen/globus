---
import { Image } from 'astro:assets'
import flynasLogo from '@/assets/images/news_type_one/company-logo-1.svg'
import saudiaLogo from '@/assets/images/news_type_one/company-logo-2.png'

interface ScheduleRow {
    id: number
    airline: 'flynas' | 'saudia'
    date: string
    route: string
    departures: string
}

const scheduleData: ScheduleRow[] = [
    {
        id: 1,
        airline: 'flynas',
        date: 'с 01.08.2025 г',
        route: 'Москва (Внуково) → Эр-Рияд',
        departures: 'Понедельник, среда, пятница',
    },
    {
        id: 2,
        airline: 'saudia',
        date: 'с 17.10.2025 г',
        route: 'Москва (Шереметьево) → Эр-Рияд',
        departures: 'Вторник, пятница, воскресенье',
    },
]
---

<section class="news-schedule-section">
    <div class="section-container">
        <h2>Полетная программа Москва-Эр-Рияд:</h2>

        <div class="schedule-table">
            <div class="table-header">
                <span class="table-cell header-cell">Авиакомпания</span>
                <span class="table-cell header-cell">Даты</span>
                <span class="table-cell header-cell">Направление</span>
                <span class="table-cell header-cell">Вылеты</span>
            </div>

            {scheduleData.map((row) => (
                <div class="table-row">
                    <div class="table-cell airline-cell">
                        {row.airline === 'flynas' ? (
                            <Image
                                src={flynasLogo}
                                alt="Flynas"
                                class="airline-logo"
                                loading="lazy"
                            />
                        ) : (
                            <Image
                                src={saudiaLogo}
                                alt="Saudia"
                                class="airline-logo"
                                loading="lazy"
                            />
                        )}
                    </div>
                    <span class="table-cell content-cell" data-label="Даты:">{row.date}</span>
                    <span class="table-cell content-cell" data-label="Направление:">{row.route}</span>
                    <span class="table-cell content-cell" data-label="Вылеты:">{row.departures}</span>
                </div>
            ))}
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .news-schedule-section {
        @include adaptive(margin-top, 60, 40);

        h2 {
            @include adaptive(font-size, 28, 22);
            @include adaptive(margin-bottom, 40, 6);
        }

        .schedule-table {
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        .table-header {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            @include adaptive(gap, 45, 20);
            @include adaptive(padding-bottom, 24, 16);
            border-bottom: 1px solid var(--color-globus-sand);

            @include mobile {
                display: none;
            }
        }

        .table-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            @include adaptive(gap, 45, 20);
            @include adaptive(padding-top, 24, 20);
            @include adaptive(padding-bottom, 24, 20);
            border-bottom: 1px solid var(--color-globus-sand);

            @include mobile {
                grid-template-columns: 1fr;
                @include adaptive(gap, 16, 16);
            }
        }

        .table-cell {
            display: flex;
            align-items: center;
        }

        .header-cell {
            @include adaptive(font-size, 20, 16);
            color: var(--color-globus-light-blue);
        }

        .airline-cell {
            @include adaptive(padding-top, 6, 6);

            @include mobile {
                justify-content: center;
                @include adaptive(margin-bottom, 0, 12);
            }

            .airline-logo {
                @include adaptive(max-width, 196, 140);
                @include adaptive(max-height, 72, 50);
                width: auto;
                height: auto;
                object-fit: contain;
            }
        }

        .content-cell {
            position: relative;
            @include adaptive(font-size, 26, 20);

            @include mobile {
                @include adaptive(padding-left, 120, 120);

                &::before {
                    content: attr(data-label);
                    position: absolute;
                    left: 0;
                    @include adaptive(font-size, 16, 16);
                    color: var(--color-globus-light-blue);
                }
            }
        }
    }
</style>
