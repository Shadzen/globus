---
import ScheduleTable from '@/components/common/ScheduleTable.astro'
import flynasLogo from '@/assets/images/news_type_one/company-logo-1.svg'
import saudiaLogo from '@/assets/images/news_type_one/company-logo-2.png'

const scheduleRows = [
    {
        logo: { src: flynasLogo.src, alt: 'Flynas' },
        cells: ['с 01.08.2025 г', 'Москва (Внуково) → Эр-Рияд', 'Понедельник, среда, пятница'] as const,
    },
    {
        logo: { src: saudiaLogo.src, alt: 'Saudia' },
        cells: ['с 17.10.2025 г', 'Москва (Шереметьево) → Эр-Рияд', 'Вторник, пятница, воскресенье'] as const,
    },
]
---

<section class="news-schedule-section">
    <div class="section-container">
        <h2>Полетная программа Москва-Эр-Рияд:</h2>

        <ScheduleTable
            headers={['Авиакомпания', 'Даты', 'Направление', 'Вылеты']}
            rows={scheduleRows}
        />
    </div>
</section>

<style lang="scss" is:global>
    .news-schedule-section {
        @include adaptive(margin-top, 60, 40);

        h2 {
            @include adaptive(font-size, 28, 22);
            @include adaptive(margin-bottom, 40, 6);
        }
    }
</style>
