---
import VideosGrid from '@/components/education/VideosGrid.astro'
import { webinarsData } from '@/data/webinars'

interface Props {
    userType?: 'tourist' | 'agent'
}

const { userType = 'agent' } = Astro.props
const base = import.meta.env.BASE_URL
---

<section class="education-videos-section _dark">
    <div class="section-container">
        <h2>Записи вебинаров</h2>

        <VideosGrid videos={webinarsData} userType={userType} />

        <div class="education-videos-footer">
            <a href={`${base}${userType}/webinar_archive/`} class="button _sized">
                <span>Архив вебинаров</span>
            </a>
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .education-videos-section {
        @include adaptive(margin-top, 120, 60);
        @include adaptive(padding-top, 80, 60);
        @include adaptive(padding-bottom, 80, 60);

        h2 {
            @include adaptive(margin-bottom, 60, 30);
        }

        .education-videos-footer {
            display: flex;
            justify-content: center;
            @include adaptive(margin-top, 60, 60);
        }
    }
</style>
