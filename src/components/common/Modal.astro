---
// src/components/common/Modal.astro
interface Props {
    id: string
}

const { id } = Astro.props
---

<div class="modal" data-modal={id} aria-hidden="true" role="dialog" aria-modal="true">
    <div class="modal-backdrop" data-modal-backdrop></div>
    <div class="modal-panel">
        <button type="button" class="modal-close" aria-label="Закрыть" data-modal-close>
            <svg
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
            >
                <path
                    d="M18 6L6 18M6 6L18 18"
                    stroke="currentColor"
                    stroke-width="1"
                />
            </svg>
        </button>
        <div class="modal-content">
            <slot />
        </div>
    </div>
</div>

<style lang="scss" is:global>
    .modal {
        @include flex-center;
        position: fixed;
        inset: 0;
        z-index: 1100;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease;

        &._active {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }
    }

    .modal-backdrop {
        position: absolute;
        inset: 0;
        background-color: rgba(0, 0, 0, 0.5);
    }

    .modal-panel {
        position: relative;
        width: 100%;
        @include adaptive(max-width, 1475, 100%);
        @include adaptive(max-height, 900, 100%);
        overflow-y: scroll;
        background-color: var(--color-globus-cream);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        z-index: 1;
    }

    .modal-close {
        @include flex-center;
        position: absolute;
        @include adaptive(width, 72, 48);
        @include adaptive(height, 72, 48);
        @include adaptive(top, 16, 8);
        @include adaptive(right, 16, 8);
        padding: 0;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-globus-blue);
        transition: opacity 0.2s;

        svg {
            width: 100%;
            height: 100%;
        }

        &:hover {
            opacity: 0.7;
        }
    }

    .modal-content {
        @include adaptive(padding-top, 80, 60);
        @include adaptive(padding-bottom, 80, 40);
        @include adaptive(padding-left, 80, 15);
        @include adaptive(padding-right, 80, 15);
    }
</style>
