---
// src/components/ContactCTA.astro
import telegramIcon from '@/assets/icons/telegram-accent.svg'
import phoneIcon from '@/assets/icons/phone-accent.svg'

interface Props {
    title?: string
    description?: string
}

const { title, description } = Astro.props
---

<section class="contact-cta _dark">
    <div class="section-container">
        {title && <h2 set:html={title} />}

        {description && <p set:html={description} />}

        <div class="contact-cta-buttons">
            <a
                href="https://t.me/+79130637716"
                class="button _sized _outline"
                target="_blank"
                rel="noopener noreferrer"
            >
                <img src={telegramIcon.src} alt="Telegram" />
                <span>8 913 063 7716</span>
            </a>

            <a href="tel:+73832000500" class="button _sized _outline">
                <img src={phoneIcon.src} alt="Телефон" />
                <span>8 (383) 2000-500</span>
            </a>

            <button type="button" class="button _sized">Оставить заявку</button>
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .contact-cta {
        @include adaptive(margin-top, 90, 60);
        @include adaptive(padding-top, 90, 60);
        @include adaptive(padding-bottom, 90, 60);

        .section-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            @include adaptive(gap, 30, 30);

            h2 {
                @include desktop {
                    width: 90%;
                }
            }

            p {
                color: var(--color-globus-light-blue) !important;
                text-align: center;

                @include desktop {
                    width: 58%;
                }
            }
        }

        .contact-cta-buttons {
            @include flex-center;
            @include adaptive(column-gap, 192, 136);
            @include adaptive(row-gap, 0, 26);
            flex-wrap: wrap;
            @include adaptive(margin-top, 44, 20);

            @include mobile {
                flex-direction: column;
                width: 100%;
            }
        }

        .button._outline {
            @include adaptive(font-size, 24, 18);
        }
    }
</style>
