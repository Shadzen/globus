---
import { Image } from 'astro:assets'
import nextAccentIcon from '@/assets/icons/next-accent.svg'

import gridItem1 from '@/assets/images/agencies/grid-item-1.jpg'
import gridItem2 from '@/assets/images/agencies/grid-item-2.jpg'
import gridItem3 from '@/assets/images/agencies/grid-item-3.jpg'
import gridItem4 from '@/assets/images/agencies/grid-item-4.jpg'
import gridItem5 from '@/assets/images/agencies/grid-item-5.jpg'
import gridItem6 from '@/assets/images/agencies/grid-item-6.jpg'
import gridItem7 from '@/assets/images/agencies/grid-item-7.jpg'

interface Props {
    userType?: 'tourist' | 'agent'
}

const { userType = 'agent' } = Astro.props
const base = import.meta.env.BASE_URL

const items = [
    {
        title: 'Заключение<br>договоров',
        image: gridItem1,
        href: `${base}${userType}/partner/`,
    },
    {
        title: 'Способы<br>оплаты',
        image: gridItem2,
        href: `${base}${userType}/payment_methods/`,
    },
    {
        title: 'Контакты<br>Менеджеров',
        image: gridItem3,
        href: `${base}${userType}/about/`,
    },
    {
        title: 'Бонусная<br>программа',
        image: gridItem4,
        href: `${base}${userType}/bonus_program/`,
    },
    {
        title: 'Фин.гарантии<br>и Образцы заполнения документов',
        image: gridItem5,
        href: `${base}${userType}/fin_guarantees/`,
    },
    {
        title: 'Рекламные<br>туры',
        image: gridItem6,
        href: `${base}${userType}/promo_tours/`,
    },
    {
        title: 'Обучение',
        image: gridItem7,
        href: `${base}${userType}/education/`,
    },
]
---

<section class="plain-grid-section _overlap-top">
    <div class="section-container">
        <div class="plain-grid">
            {
                items.map((item) => (
                    <a href={item.href} class="plain-grid-item">
                        <span class="plain-grid-item-image">
                            <Image
                                src={item.image}
                                alt={item.title.replace(/<br\s*\/?>/gi, ' ')}
                                loading="lazy"
                                quality={100}
                            />
                        </span>
                        <span class="plain-grid-item-content">
                            <h3 set:html={item.title} />
                            <span class="plain-grid-item-arrow">
                                <img src={nextAccentIcon.src} alt="" />
                            </span>
                        </span>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style lang="scss" is:global>
    .plain-grid-section {
        @include adaptive(margin-top, 120, 60);
        position: relative;
        z-index: 10;

        &._overlap-top {
            @include adaptive(margin-top, -240, -200);
        }

        .plain-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            @include adaptive(column-gap, 18, 20);
            @include adaptive(row-gap, 58, 30);

            @include mobile {
                grid-template-columns: 1fr;
            }
        }

        .plain-grid-item {
            position: relative;
            display: block;
            text-decoration: none;
            cursor: pointer;
            @include adaptive(padding, 38, 38);
            @include adaptive(height, 501, 360);

            @include mobile {
                br {
                    display: inline;
                }
            }

            &:hover {
                opacity: 1;

                .plain-grid-item-content,
                .plain-grid-item-image {
                    transform: scale(1.05);
                }
            }
        }

        .plain-grid-item-image {
            @include abs-default;
            transition: transform 0.3s;

            img {
                display: block;
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: center;
            }

            &::after {
                content: '';
                @include abs-default;
                z-index: 1;
                pointer-events: none;
                background: linear-gradient(180deg, rgba(0, 0, 0, 0) 62.45%, rgba(0, 0, 0, 0.65) 100%), linear-gradient(180deg, rgba(0, 0, 0, 0.65) 22%, rgba(0, 0, 0, 0) 45.35%);
            }
        }

        .plain-grid-item-content {
            position: relative;
            display: block;
            width: 100%;
            height: 100%;
            transition: transform 0.3s;
        }

        h3 {
            position: absolute;
            z-index: 2;
            left: 0;
            top: 0;
            color: var(--color-globus-cream);
            @include adaptive(font-size, 28, 28);
            white-space: normal;
        }

        .plain-grid-item-arrow {
            position: absolute;
            z-index: 2;
            right: 0;
            bottom: 0;
            @include adaptive(width, 81, 62);
            @include adaptive(height, 81, 62);

            img {
                display: block;
                width: 100%;
                height: 100%;
                object-fit: contain;
            }
        }
    }
</style>
