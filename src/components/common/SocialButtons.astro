---
// Reusable social buttons: MAX, message, and Telegram, round links with sand background.
// variant: 'default' = inline in layout, 'fixed' = fixed on screen (e.g. side strip).
import maxIcon from '@/assets/icons/max4.png'
import messageIcon from '@/assets/icons/soobshhenie-3.png'
import telegramIcon from '@/assets/icons/telegram-1.png'

interface Props {
    variant?: 'default' | 'fixed'
    maxHref?: string
    messageHref?: string
    telegramHref?: string
}

const {
    variant = 'default',
    maxHref = '#',
    messageHref = '#',
    telegramHref = '#',
} = Astro.props
---

<div class="social-buttons" class:list={[variant === 'fixed' && '_fixed']}>
    <a
        href={maxHref}
        class="social-buttons-link"
        aria-label="MAX"
        target="_blank"
        rel="noopener noreferrer"
    >
        <img src={maxIcon.src} alt="" width="24" height="24" />
    </a>
    <a
        href={messageHref}
        class="social-buttons-link"
        aria-label="Сообщения"
        target="_blank"
        rel="noopener noreferrer"
    >
        <img src={messageIcon.src} alt="" width="24" height="24" />
    </a>
    <a
        href={telegramHref}
        class="social-buttons-link"
        aria-label="Telegram"
        target="_blank"
        rel="noopener noreferrer"
    >
        <img src={telegramIcon.src} alt="" width="24" height="24" />
    </a>
</div>

<style lang="scss" is:global>
    .social-buttons {
        @include flex-center;
        @include adaptive(gap, 24, 24);
        border-radius: 500px;

        &._fixed {
            position: fixed;
            z-index: 100;
            @include adaptive(right, 24, 16);
            @include adaptive(bottom, 24, 16);
            background-color: var(--color-globus-sand);
        }

        .social-buttons-link {
            @include flex-center;
            height: 100%;
            @include adaptive(height, 80, 80);
            @include adaptive(width, 80, 80);
            border-radius: 50%;
            background-color: var(--color-globus-sand);
            transition: transform 0.2s, opacity 0.2s;

            img {
                width: 60%;
                height: 60%;
                object-fit: contain;
            }

            &:hover {
                opacity: 0.9;
                transform: scale(1.05);
            }
        }
    }
</style>
