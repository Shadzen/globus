---
import chevronDown from '@/assets/icons/chevron-down.svg'

interface AccordionSection {
    id: string
    title: string
    content: string
}

interface Props {
    sections: AccordionSection[]
    type?: 'docs' | string
    theme?: 'light' | 'dark'
    largeText?: boolean
}

const { sections, type, theme = 'light', largeText = false } = Astro.props
---

<div
    class:list={[
        'accordion',
        { _docs: type === 'docs', _dark: theme === 'dark', '_large-text': largeText },
    ]}
>
    {
        sections.map((section) => (
            <div class="accordion-item" data-accordion-item>
                <div class="divider" />
                <button class="accordion-header" data-accordion-button aria-expanded="false">
                    <h3>{section.title}</h3>
                    <img src={chevronDown.src} alt="" class="accordion-icon" />
                </button>
                <div class="accordion-content" data-accordion-content>
                    <div class="accordion-content-inner" set:html={section.content} />
                </div>
            </div>
        ))
    }
</div>

<style lang="scss" is:global>
    .accordion {
        display: flex;
        flex-direction: column;

        .accordion-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            @include adaptive(gap, 20, 16);
            background: none;
            border: none;
            @include adaptive(padding-top, 44, 22);
            @include adaptive(padding-bottom, 44, 22);
            padding-left: 0;
            padding-right: 0;
            cursor: pointer;
            text-align: left;

            h3 {
                color: var(--color-globus-blue);
                @include adaptive(font-size, 28, 26);
                flex: 1;
            }
        }

        &._docs {
            .accordion-item:first-child .divider {
                display: none;
            }

            // .accordion-header {
            //     padding-left: 0;
            // }

            // .accordion-content-inner {
            //     width: 100%;
            // }
        }

        .accordion-icon {
            flex-shrink: 0;
            @include adaptive(width, 24, 20);
            @include adaptive(height, 24, 20);
            transition: transform 0.3s ease;
        }

        .accordion-header[aria-expanded='true'] .accordion-icon {
            transform: rotate(180deg);
        }

        .accordion-content {
            overflow: hidden;
            max-height: 0;
            transition: max-height 0.4s ease;
        }

        .accordion-content-inner {
            @include adaptive(padding-bottom, 44, 22);

            // @include desktop {
            //     width: 80%;
            //     margin: 0 auto;
            // }

            p {
                @include adaptive(font-size, 20, 18);
            }
        }

        &._dark {
            .accordion-header h3 {
                color: var(--color-globus-cream);
            }

            .accordion-content-inner {
                p, a {
                    color: var(--color-globus-cream);
                }
            }
        }

        &._large-text {
            .accordion-content-inner {
                p {
                    @include adaptive(font-size, 28, 18);
                }
            }
        }
    }
</style>
