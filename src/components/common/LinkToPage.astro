---
interface Props {
    title?: string
    buttonText?: string
    href?: string
    userType?: 'tourist' | 'agent'
}

const {
    title = 'Подобрать тур самостоятельно',
    userType = 'agent',
    href,
    buttonText,
} = Astro.props

const base = import.meta.env.BASE_URL

const defaultHref = userType === 'agent'
    ? `${base}${userType}/tour_search/`
    : `${base}tourist/tourvisor`

const defaultButtonText = userType === 'agent'
    ? 'Найти'
    : 'Найти'

const linkHref = href ?? defaultHref
const linkText = buttonText ?? defaultButtonText
---

<section class="link-to-page-section _dark">
    <div class="section-container">
        <h2 set:html={title} />

        <a href={linkHref} class="button _sized">
            <span>{linkText}</span>
        </a>
    </div>
</section>

<style lang="scss" is:global>
    .link-to-page-section {
        @include adaptive(margin-top, 120, 60);
        @include adaptive(padding-top, 60, 40);
        @include adaptive(padding-bottom, 60, 40);

        .section-container {
            @include flex-center-between;
            @include adaptive(gap, 40, 30);

            @include mobile {
                flex-direction: column;
                align-items: stretch;
            }
        }

        h2 {
            text-align: left;
            @include adaptive(font-size, 60, 32);
            @include adaptive(padding-top, 8, 0);
            flex: 1;

            @include mobile {
                text-align: center;
            }
        }

        .button._sized {
            @include adaptive(min-width, 513, 100%);
            flex-shrink: 0;

            &:is(a, button) {
                @include adaptive(letter-spacing, 3.2, 3.6);
            }
        }
    }
</style>
