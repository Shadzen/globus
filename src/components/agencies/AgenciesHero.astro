---
import HeroNav from '@/components/common/HeroNav.astro'

import heroDesktop from '@/assets/images/agencies/hero-1.jpg'
import heroMobile from '@/assets/images/agencies/hero-1-mobile.jpg'

import { BREAKPOINTS } from '@/scripts/utils'

interface Props {
    userType?: 'tourist' | 'agent'
}

const { userType = 'agent' } = Astro.props
const base = import.meta.env.BASE_URL
---

<section class="hero-section agencies-hero _type-screen">
    <picture class="hero-bg _overlay-darker">
        <source media={`(max-width: ${BREAKPOINTS.mobile}px)`} srcset={heroMobile.src} />
        <img src={heroDesktop.src} alt="" loading="eager" decoding="async" />
    </picture>

    <HeroNav
        items={[
            { label: 'Главная', href: `${base}${userType}/` },
            { label: 'Рекламные туры', href: `${base}${userType}/promo_tours/` },
            { label: 'Мальдивы: Рекламный тур с 22.07 по 01.08.2025' },
        ]}
    />

    <div class="hero-content">
        <h1>Агентствам</h1>
        <p>Вся необходимая информация <br /> для агентств и полезные ссылки</p>
    </div>
</section>

<style lang="scss" is:global>
    .agencies-hero.hero-section {
        @include adaptive(padding-top, 560, 360);
        text-align: center;

        @include mobile {
            br {
                display: inline;
            }
        }

        h1 {
            @include adaptive(font-size, 74, 60);
        }

        p {
            color: var(--color-globus-cream);
        }
    }
</style>
