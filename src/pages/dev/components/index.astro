}

const includedColumns: IncludedItem[][] = [
    [
        { text: 'Авиаперелет Москва — Эр-Рияд — Москва\n(прямые рейсы Flynas, Saudia airlines)*' },
        { text: 'Авиаперелет Эр-Рияд — Аль-Ула — Эр-Рияд\n(прямые рейсы Flynas, Saudia airlines)*' },
        { text: 'Встреча/проводы в аэропорту.' },
        { text: 'Размещение в указанных отелях\nили аналогичных отелях той же\nкатегории с завтраками.' },
        { text: 'Проживание в отеле Sahary Al Ula\nс полупансионом (включая завтрак и ужин).' },
    ],
    [
        { text: 'Мероприятия, указанные в программе.' },
        { text: 'Входные билеты по программе.' },
        { text: 'Англоговорящий гид в Эр-Рияде.' },
        { text: 'Экскурсия по Аль-Уле на автобусе SIC.' },
        { text: 'Обед на местной ферме в Аль-Уле.' },
        { text: 'Англоговорящий местный координатор\nтура на протяжении всего тура.' },
    ],
    [
        { text: 'Частный транспорт на современном комфортабельном автомобиле по программе.' },
