<Layout title={`Component demos - ${COMPANY_NAME}`} heroTextColor="dark">
    <HeroNav
        darkText={true}
        items={[{ label: 'Главная', href: `${base}${devHeroUserType}/` }, { label: 'Компоненты' }]}
