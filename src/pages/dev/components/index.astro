                <img src={heroDesktop7.src} alt="" loading="eager" decoding="async" />
            </picture>
        </div>
    </HeroCustom>

    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={80} />

    <HeroCustom type="screen">
        <picture class="custom-image _overlay-darker">
            <source media={`(max-width: ${BREAKPOINTS.mobile}px)`} srcset={heroMobile2.src} />
            <img src={heroDesktop2.src} alt="" loading="eager" decoding="async" />
