        </picture>
        <picture class="custom-image _size-1 _overlay-gradient">
            <source media={`(max-width: ${BREAKPOINTS.mobile}px)`} srcset={heroMobile4.src} />
            <img src={heroDesktop4.src} alt="" loading="eager" decoding="async" />
        </picture>
    </HeroCustom>

    <SectionGap size={20} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={40} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={60} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={100} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={120} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={20} />

    <NewsGrid userType={devHeroUserType} />

    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={80} />

    <section>
        <div class="section-container">
            <picture
                class="custom-image _size-1"
                data-pswp-lightbox
                data-pswp-media="video"
                data-pswp-video-src={fullscreenDemoVideoSrc}
                data-pswp-poster={heroDesktop5.src}
            >
                <source media={`(max-width: ${BREAKPOINTS.mobile}px)`} srcset={heroMobile5.src} />
                <img src={heroDesktop5.src} alt="" loading="eager" decoding="async" />
            </picture>
        </div>
    </section>

    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={80} />

    <section>
        <div class="section-container">
            <h2>Open fullscreen image demo</h2>
            <br />
            <br />
            <picture
                class="custom-image _size-1"
                data-pswp-lightbox
                data-pswp-src={heroDesktop3.src}
                data-pswp-width={heroDesktop3.width}
                data-pswp-height={heroDesktop3.height}
                data-pswp-alt=""
            >
                <source media={`(max-width: ${BREAKPOINTS.mobile}px)`} srcset={heroMobile3.src} />
                <img src={heroDesktop3.src} alt="" loading="eager" decoding="async" />
            </picture>
        </div>
    </section>

    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />
    <SectionGap size={80} />

    <section>
        <div class="section-container">
            <CustomGrid>
                <div class="custom-grid-row">
                    <div class="custom-column">
                        <p>
                            Встречайте 2026 год на грандиозном праздничном ужине c выступлением
                            настоящих легенд, многократных обладателей Грэмми, исполнителей всемирно
                            известных хитов!
                        </p>
                    </div>
                    <picture
                        class="custom-image _size-1"
                        data-pswp-lightbox
                        data-pswp-media="video"
                        data-pswp-video-src={fullscreenDemoVideoSrc}
                        data-pswp-poster={photo1.src}
                    >
                        <img src={photo1.src} alt="" loading="eager" decoding="async" />
                    </picture>
                </div>
                <div class="custom-grid-row">
                    <picture class="custom-image _size-3">
                        <img src={photo2.src} alt="" loading="eager" decoding="async" />
                    </picture>
                    <div class="custom-column">
                        <p>
                            Гостей ждёт открытая площадка с видом на Пальму Джумейра и небоскрёбы
                            Дубая, живая музыка и оркестр. Дресс-код — black tie, атмосфера —
                            настоящая зимняя сказка. Роскошный ужин с изысканными деликатесами —
                            чёрной икрой, белым трюфелем и премиальным шампанским — станет настоящим
                            украшением новогодней ночи.
                        </p>
                        <br />
                        <p>
                            Слушайте вживую Moves Like Jagger, She Will Be Loved и This Love под
                            аккомпанемент новогодних фейерверков! Вы можете выбрать различные
                            категории новогоднего ужина под открытым небом: «Premium» (Премиум),
                            «Красный круг» или «Золотой круг»:
                        </p>
                    </div>
                </div>
            </CustomGrid>
        </div>
    </section>

    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />

    <CountryRules />

    <SectionGap size={80} />
    <hr style="margin: 0; border-color: red;" />

