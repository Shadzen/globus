---
// Agent-only layout: used by agent/tour_search and agent/tour_search_login.
// Styles here are built into a separate CSS chunk for deployment on another domain.
import '../styles/fonts.scss'
import Header from '@/components/common/Header.astro'
import Modal from '@/components/common/Modal.astro'
import ContactFormPopupContent from '@/components/main/ContactFormPopupContent.astro'

interface Props {
    title: string
    userType?: 'tourist' | 'agent'
    heroTextColor?: 'light' | 'dark'
}

const { title, userType = 'agent', heroTextColor = 'dark' } = Astro.props
const base = import.meta.env.BASE_URL
---

<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="height=device-height, width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no"
        />
        <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`.replace(/\/+/g, '/')} />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <Header userType={userType} heroTextColor={heroTextColor} />
        <main>
            <slot />
        </main>
        <Modal id="contact-popup">
            <ContactFormPopupContent />
        </Modal>
        <script src="@/scripts/agent-main.ts"></script>
    </body>
</html>

<style lang="scss" is:global>
    @use '@/styles/layout-base.scss';
</style>
